exports[`rendered post snapshots > 'Backlinks' 1`] = `
"<div class=\\"text\\" id=\\"b51995750\\">
      A <a href=\\"https://en.wikipedia.org/wiki/Backlink\\"><strong>backlink</strong></a> is a reference to a page which links to the page the reader is currently on.
      <div class=\\"children\\"></div>
    </div><div class=\\"text\\" id=\\"b37389272\\">
      Backlinks are cleverly exposed in the <a href=\\"https://en.wikipedia.org/wiki/Special:WhatLinksHere/Backlink\\">What links here</a> tool in MediaWiki.
      <div class=\\"children\\"></div>
    </div>"
`;

